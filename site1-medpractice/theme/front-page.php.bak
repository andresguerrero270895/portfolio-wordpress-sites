<!-- ═══════════════════════════════════════════
     LOCATIONS / STATES SECTION
════════════════════════════════════════════ -->
<section class="mp-section mp-locations-section" id="locations" aria-label="Locations">
  <div class="mp-container">

    <div class="mp-section-header">
      <span class="mp-section-label">Our Locations</span>
      <h2 class="mp-section-title">Medical Practices Across<br>30+ States</h2>
      <p class="mp-section-desc">
        Browse verified medical practice opportunities in your preferred state.
        Each listing is thoroughly vetted by our team.
      </p>
    </div>

    <!-- Search -->
    <div class="mp-search-bar">
      <span class="mp-search-bar__icon">🔍</span>
      <input
        type="text"
        id="mp-state-search"
        class="mp-search-bar__input"
        placeholder="Search states… e.g. California, Texas, Florida"
        aria-label="Search states"
      >
    </div>

    <!-- States Grid -->
    <div class="mp-states-grid" id="mp-states-grid">
      <?php
      $states_query = new WP_Query( array(
        'post_type'      => 'state_landing',
        'posts_per_page' => 30,
        'orderby'        => 'title',
        'order'          => 'ASC',
        'post_status'    => 'publish',
      ) );

      if ( $states_query->have_posts() ) :
        while ( $states_query->have_posts() ) :
          $states_query->the_post();
          $state_code  = get_post_meta( get_the_ID(), '_mp_state_code', true );
          $practice_ct = get_post_meta( get_the_ID(), '_mp_practices_count', true );
      ?>
        <a
          href="<?php the_permalink(); ?>"
          class="mp-state-card"
          aria-label="View practices in <?php the_title_attribute(); ?>"
          data-state="<?php echo esc_attr( strtolower( get_the_title() ) ); ?>"
        >
          <span class="mp-state-card__code"><?php echo esc_html( $state_code ?: substr( get_the_title(), 0, 2 ) ); ?></span>
          <span class="mp-state-card__name"><?php the_title(); ?></span>
          <span class="mp-state-card__count"><?php echo esc_html( $practice_ct ?: '50+' ); ?> practices</span>
        </a>
      <?php
        endwhile;
        wp_reset_postdata();
      else :
      ?>
        <div class="mp-states-empty">
          <p>State pages are being generated. Please <a href="<?php echo esc_url( admin_url( 'edit.php?post_type=state_landing' ) ); ?>">check the admin</a> or refresh in a moment.</p>
        </div>
      <?php endif; ?>
    </div><!-- /.mp-states-grid -->

  </div><!-- /.mp-container -->
</section>


